PORT=3001
LOG_LEVEL=info
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portfolio
DATABASE_SSL=false
ADMIN_ID=admin
ADMIN_PASSWORD=aadmin1234
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_SESSION_TTL_HOURS=12
# Use "none" when the frontend is hosted on a different domain, such as Vercel -> Render.
ADMIN_COOKIE_SAME_SITE=lax

# Comma-separated list for deployed frontends.
CORS_ORIGIN=http://localhost:5173

# Optional SMTP config for recruiter acknowledgement emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
